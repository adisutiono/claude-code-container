{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(make build)",
      "Bash(make status)",
      "Bash(make clean)",
      "Bash(bash tests/container-checks.sh)",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git branch*)",
      "Bash(git checkout -b *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git push origin *)",
      "Bash(gh issue:*)",
      "Bash(git push:*)",
      "Bash(gh pr:*)",
      "Bash(npm install*)",
      "Bash(npm test*)",
      "Bash(pip install*)",
      "Bash(ls *)",
      "Bash(cat *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(grep *)",
      "Bash(find *)",
      "Bash(podman --version)",
      "Bash(node --version)",
      "Bash(claude --version)",
      "Read(/workspaces/**)",
      "Edit(src/**)",
      "Edit(docs/**)",
      "Edit(tests/**)",
      "Edit(.claude/commands/**)",
      "Write(src/**)",
      "Write(docs/**)",
      "Write(tests/**)",
      "Edit(.knowledge/**)",
      "Write(.knowledge/**)"
    ],
    "deny": [
      "Bash(git push* main*)",
      "Bash(git push --force*)",
      "Bash(sudo *)",
      "Bash(rm -rf *)",
      "Edit(.devcontainer/config/*)",
      "Edit(scripts/wsl2/*)"
    ]
  },
  "model": "sonnet"
}
