#!/usr/bin/env bash
# Pre-commit hook: scan .claude/memory/ files for potential secrets.
# Install: ln -sf ../../scripts/hooks/pre-commit .git/hooks/pre-commit
set -euo pipefail

# Check staged memory and knowledge files
MEMORY_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '^(\.claude/memory/|\.knowledge/)' || true)

if [[ -z "${MEMORY_FILES}" ]]; then
  exit 0
fi

# Patterns that suggest leaked secrets (case-insensitive where appropriate)
SECRET_PATTERNS=(
  # API keys and tokens
  'sk-[a-zA-Z0-9]{20,}'                        # OpenAI / Anthropic style keys
  'ghp_[a-zA-Z0-9]{36}'                         # GitHub personal access tokens
  'gho_[a-zA-Z0-9]{36}'                         # GitHub OAuth tokens
  'github_pat_[a-zA-Z0-9_]{80,}'                # GitHub fine-grained PATs
  'ghs_[a-zA-Z0-9]{36}'                         # GitHub app tokens
  'glpat-[a-zA-Z0-9_-]{20,}'                    # GitLab PATs
  'AKIA[0-9A-Z]{16}'                            # AWS access key IDs
  'xox[bpors]-[a-zA-Z0-9-]{10,}'                # Slack tokens
  'eyJ[a-zA-Z0-9_-]{20,}\.[a-zA-Z0-9_-]{20,}'  # JWTs

  # Generic secret patterns
  'PRIVATE KEY-----'                             # PEM private keys
  'password\s*[:=]\s*["\x27][^\s]{8,}'           # password assignments
  'secret\s*[:=]\s*["\x27][^\s]{8,}'             # secret assignments
  'token\s*[:=]\s*["\x27][^\s]{8,}'              # token assignments

  # High-entropy strings (base64 blobs > 40 chars, likely keys)
  '[A-Za-z0-9+/]{40,}={0,2}'
)

FOUND=0
for file in ${MEMORY_FILES}; do
  content=$(git show ":${file}" 2>/dev/null || true)
  if [[ -z "${content}" ]]; then
    continue
  fi

  for pattern in "${SECRET_PATTERNS[@]}"; do
    if echo "${content}" | grep -qE "${pattern}"; then
      if [[ ${FOUND} -eq 0 ]]; then
        echo "==> SECRET SCAN: potential secrets detected in memory files"
        echo ""
      fi
      echo "  BLOCKED  ${file}"
      echo "           Pattern: ${pattern}"
      echo "           Match:   $(echo "${content}" | grep -oE "${pattern}" | head -1 | cut -c1-40)..."
      echo ""
      FOUND=1
      break
    fi
  done
done

if [[ ${FOUND} -eq 1 ]]; then
  echo "Commit blocked. Review the files above and remove sensitive data."
  echo "If this is a false positive, commit with: git commit --no-verify"
  exit 1
fi
